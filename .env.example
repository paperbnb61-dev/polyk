COLLECT_MARKETS=btc
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_TOKEN=
COLLECT_INTERVAL_MS=5000
COLLECT_TICK_TIMEOUT_MS=4500
COLLECT_REQUEST_TIMEOUT_MS=3500
COLLECT_REQUEST_RETRIES=0
COLLECT_OUT_FILE=data/market-snapshots.jsonl
COLLECT_TZ=utc
COLLECT_PRICE_SOURCE=clob_market
COLLECT_ONLY_ON_CHANGE=true
COLLECT_INCLUDE_SPOT_CONTEXT=false

UI_COLLECT_MARKET=btc
UI_COLLECT_SLUG=
UI_COLLECT_URL=
UI_COLLECT_INTERVAL_MS=5000
UI_COLLECT_TICK_TIMEOUT_MS=12000
UI_COLLECT_OUT_FILE=data/ui-market-snapshots.jsonl

BACKTEST_DATA_DIR=data
BACKTEST_SOURCE=auto
BACKTEST_DB_COLLECTOR=all
BACKTEST_DB_LIMIT=0
BACKTEST_MARKET=btc
BACKTEST_STAKE_USD=100
BACKTEST_FEE_RATE=0.00072
BACKTEST_MAX_PAIR_SUM_CENTS=97,98,99,100
BACKTEST_FIRST_LEG_MAX_CENTS=45,55,65,75
BACKTEST_SECOND_LEG_TIMEOUT_SEC=3,5,8,12
BACKTEST_MAX_LEGS_PER_SIDE=1,2,3,4
BACKTEST_ADD_STEP_CENTS=1,2,3
BACKTEST_MAX_ENTRIES_PER_SLUG=1
BACKTEST_FORCE_SECOND_LEG=true
BACKTEST_MIN_TICKS_PER_SLUG=3
BACKTEST_TOP_N=10
BACKTEST_MIN_TRADES=10
BACKTEST_MAX_FORCED_RATE_PCT=60

PAPER_MARKET=btc
PAPER_POLL_INTERVAL_MS=400
PAPER_INITIAL_USD=10000
PAPER_FEE_RATE=0.00072
PAPER_LOG_FILE=data/paper-logs.jsonl
PAPER_PNL_SUMMARY_FILE=data/paper-pnl-summary.json
PAPER_PNL_REPORT_ENABLED=true
PAPER_PNL_REPORT_INTERVAL_HOURS=1
PAPER_TELEGRAM_ON_BUY=false
PAPER_TELEGRAM_ON_WINDOW_END=false

# Celecula3-style accumulation (defaults tuned to @celecula3 BTC 15m)
CELE_SHARES_PER_ORDER=12
CELE_MAX_BUYS_PER_SIDE=64
CELE_MAX_SUM_AVG=0.985
CELE_MAX_INSTANT_SUM_CENTS=103
CELE_BALANCE_PRIORITY=true
CELE_MAX_SIDE_IMBALANCE_SHARES=144
CELE_SECOND_SIDE_MS=280
CELE_REVERSAL_DELTA_CENTS=2
CELE_MIN_PRICE_CENTS=2
CELE_MAX_PRICE_CENTS=95
CELE_BUY_COOLDOWN_MS=80
CELE_ENTRY_EITHER_SIDE_MAX_CENTS=58
CELE_CHASE_EXPENSIVE_SIDE=true

# --- Live trading (npm run live) ---
# Start with LIVE_TRADING_MODE=dry, then switch to live only after LIVE_CONFIRM=yes
LIVE_TRADING_MODE=dry
LIVE_CONFIRM=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
POLYMARKET_SIGNATURE_TYPE=1
POLYGON_RPC_URL=
POLYMARKET_CHAIN_ID=137
LIVE_SLIPPAGE_CENTS=2
LIVE_NEG_RISK=false
# 0 = unlimited (no daily buy cap)
LIVE_MAX_BUY_USD_PER_DAY=0
LIVE_LOG_FILE=data/live-logs.jsonl
LIVE_DRY_PNL_SUMMARY_FILE=data/dry-pnl-summary.json
# PnL summary to Telegram every 2h (WINDOW END est PnL, not PAIR DONE)
LIVE_PNL_REPORT_ENABLED=true
LIVE_PNL_REPORT_INTERVAL_HOURS=2
# false = no spam on each buy/window (only periodic summary)
LIVE_TELEGRAM_ON_BUY=false
LIVE_TELEGRAM_ON_WINDOW_END=false
LIVE_MARKET=btc
LIVE_POLL_INTERVAL_MS=400
